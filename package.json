{
  "name": "maria-matera",
  "version": "0.1.0",
  "private": true,
  "description": "E-commerce de joyeria de lujo Maria Matera (monorepo)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:api": "pnpm --filter @maria-matera/api dev",
    "prepare": "pnpm --filter @maria-matera/shared build",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.0"
  }
}
