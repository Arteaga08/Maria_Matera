# ============================================================
# API — entorno DESARROLLO (plantilla)
# Copia este archivo a .env.development.local y rellena valores reales.
# NUNCA subas .env.development.local al repositorio.
# ============================================================

NODE_ENV=development
PORT=4000

# MongoDB (Atlas o local). Usuario con minimo privilegio.
MONGO_URI=mongodb://127.0.0.1:27017/maria_matera_dev

# Secretos JWT — minimo 32 caracteres cada uno y DISTINTOS entre si.
JWT_ACCESS_SECRET=cambia_esto_access_secret_minimo_32_caracteres_xx
JWT_REFRESH_SECRET=cambia_esto_refresh_secret_minimo_32_caracteres_y

# Clave de cifrado (AES-256-GCM) para secretos at-rest como el TOTP 2FA. Minimo 32 caracteres.
ENCRYPTION_KEY=cambia_esto_encryption_key_minimo_32_caracteres_z

# Vigencia de tokens (opcionales; valores por defecto si se omiten).
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# URL publica del frontend (para construir enlaces de correo). Default: primer CLIENT_URL.
APP_URL=http://localhost:3000

# Origenes permitidos del frontend (separados por coma). Compartido por CORS y verifyOrigin.
CLIENT_URL=http://localhost:3000
