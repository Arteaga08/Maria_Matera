# ============================================================
# API — entorno PRODUCCION (plantilla)
# Copia este archivo a .env.production.local y rellena valores reales.
# Los secretos reales deben vivir en el secrets manager del hosting, no en el repo.
# ============================================================

NODE_ENV=production
PORT=4000

# MongoDB Atlas (cadena con SRV). Usuario con minimo privilegio + IP allowlist.
MONGO_URI=

# Secretos JWT — minimo 48 caracteres en produccion y DISTINTOS entre si. Rotar si se sospecha exposicion.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Clave de cifrado (AES-256-GCM) para secretos at-rest (TOTP 2FA). Minimo 48 caracteres en produccion.
ENCRYPTION_KEY=

# Vigencia de tokens.
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# URL publica del frontend (para enlaces de correo).
APP_URL=https://www.mariamatera.com

# Origenes permitidos del frontend en produccion (HTTPS, separados por coma).
CLIENT_URL=https://www.mariamatera.com

# Cloudinary (subida de imagenes) — requerido en produccion.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Correo (Gmail + Nodemailer). EMAIL_PASS = App Password de Gmail.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Maria Matera <no-reply@mariamatera.com>

# Telegram (alertas internas al dueno).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry (monitoreo de errores). Opcional — si se omite, Sentry no se inicializa.
SENTRY_DSN=

# Stripe (pagos) — requerido en produccion. Usar claves live (sk_live_...) y el
# signing secret del endpoint de webhook configurado en el dashboard de Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mercado Pago (pagos MX con MSI) — requerido en produccion. Usar el access
# token de produccion (APP_USR-...) y el signing secret del webhook
# configurado en el panel de Mercado Pago. Ambos son secretos: minimo 32
# caracteres.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
